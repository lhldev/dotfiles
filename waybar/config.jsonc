{
    "layer": "top",
	"width": 1000,
    "modules-left": ["cpu", "temperature#cpu", "custom/gputemp", "pulseaudio"],
    "modules-center": ["clock#left", "hyprland/workspaces", "clock#right"],
    "modules-right": ["network", "bluetooth"],
    "clock#left": {
        "format": "{:%H}"
	},
    "clock#right": {
        "format": "{:%M}"
	},
	"cpu": {
		"format": "ï‹› {usage}%",
		"interval": 5
	},
	"temperature#cpu": {
		"hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
		"format": "ï‹‰ {temperatureC}Â°C",
		"interval": 5
	},
	"custom/gputemp": {
		"exec": "~/.config/waybar/scripts/gputemp.sh",
		"interval": 5,
		"format": "ï‹‰ {}Â°C"
	},
	"network": {
		"format-wifi": "ï‡«  {signalStrength}%",
		"format-ethernet": "ï›¿ ",
		"format-disconnected": "ó°–ª ",
		"interval": 10,
		"on-click": "nm-connection-editor"
	},
	"bluetooth": {
		"format-on": "ïŠ”",
		"format-off": "ó°‚²",
		"format-disabled": "ó°‚²",
		"format-connected": "ïŠ” {num_connections}",
		"interval": 10,
		"on-click": "blueman-manager"
	},
	"pulseaudio": {
		"format": "{icon} {volume}%",
		"format-bluetooth": "ïŠ”{icon} {volume}%",
		"format-muted": "ï€¦",
		"format-icons": {
			"headphone": "ï€¥",
			"hands-free": "ó°‚‘",
			"headset": "ó°‚‘",
			"phone": "ï‚•",
			"phone-muted": "î´—",
			"portable": "ï‚•",
			"car": "ï†¹",
			"default": ["ó°–€", "ó°•¾"]
		},
		"scroll-step": 1,
		"on-click": "pavucontrol"
	},
	"hyprland/workspaces": {
		"format": "{name} {icon} ",
		"format-icons": {
			"1": "",
			"2": "",
			"3": "",
			"4": "",
			"5": "",
			"active": "ï†’",
			"default": "ï„‘"
		},
	}
}
